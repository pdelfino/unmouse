{
  "manifest_version": 3,
  "name": "Unmouse",
  "version": "0.1.0",
  "description": "Free yourself from the mouse. Select and copy text using only your keyboard.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "activate-unmouse": {
      "suggested_key": {
        "default": "MacCtrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Activate Unmouse visual mode"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "lib/utils.js",
        "lib/keyboard_utils.js",
        "lib/dom_utils.js",
        "lib/rect.js",
        "lib/handler_stack.js",
        "lib/settings.js",
        "content_scripts/mode.js",
        "content_scripts/ui_component.js",
        "content_scripts/scroller.js",
        "content_scripts/mode_key_handler.js",
        "content_scripts/mode_visual.js",
        "content_scripts/hud.js",
        "content_scripts/unmouse.js"
      ],
      "css": [
        "content_scripts/unmouse.css"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content_scripts/unmouse.css",
        "pages/hud_page.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
